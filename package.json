{
  "name": "gitlab-status-monitor",
  "version": "0.1.10",
  "description": "Tray application for monitoring GitLab pipeline status with traffic lights",
  "main": "src/main.js",
  "author": {
    "name": "Jimmy Ahs",
    "email": "jimmyahs@gmail.com"
  },
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "test": "node --test test/config.test.js test/status.test.js",
    "bump:build-version": "npm version patch --no-git-tag-version",
    "build": "npm run bump:build-version && electron-builder --publish never",
    "build:mac": "npm run bump:build-version && electron-builder --mac dmg pkg --publish never",
    "build:win": "npm run bump:build-version && electron-builder --win nsis --publish never",
    "build:linux": "npm run bump:build-version && electron-builder --linux AppImage deb --publish never"
  },
  "devDependencies": {
    "electron": "^31.2.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.example.gitlab-status-monitor",
    "productName": "GitLab Status Monitor",
    "asar": false,
    "files": [
      "src/**/*",
      "package.json",
      "!**/._*",
      "!**/.DS_Store"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "pkg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "maintainer": "Jimmy Ahs <jimmyahs@gmail.com>",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Development"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
